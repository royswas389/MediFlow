{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && pnpm install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/mediflow run build",
  "outputDirectory": "artifacts/mediflow/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
